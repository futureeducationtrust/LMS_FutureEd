# Core runtime
NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://user:password@localhost:5432/futureed
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me

# CORS / frontend
CORS_ORIGIN=http://localhost:3000
API_BASE_URL=http://localhost:5000/api/v1
FRONTEND_URL=http://localhost:3000

# ── Email transport — set ONE (priority order: Resend → Brevo API → SMTP) ───
#
# Option A — Brevo HTTP API  ← RECOMMENDED for Render (free 300/day)
#   1. brevo.com → Senders & IPs → Add sender → verify your Gmail
#   2. brevo.com → SMTP & API → API Keys → Create key
#   Works on Render (HTTPS), no DNS records — just verify sender email
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Option B — Resend (HTTPS, free 3000 emails/month)
#   Requires a verified sending DOMAIN (cannot send FROM @gmail.com)
#   resend.com → API Keys → Create Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
#
# Option C — SMTP (local dev only — Render blocks all SMTP ports)
#   Works locally with Gmail App Password or Brevo SMTP credentials
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
#
# Sender address shown in inbox (must be verified in Brevo or Resend)
SMTP_FROM="FutureEd LMS <futureeducationtrust@gmail.com>"
#
# Optional: hosted logo URL for emails (falls back to embedded base64 if not set)
LOGO_URL=


